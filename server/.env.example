# Copy to `server/.env` (or repo root `.env`) and fill in values.
# See README for Supabase and Groq setup.

SUPABASE_URL=
SUPABASE_ANON_KEY=
GROQ_API_KEY_1=

# Optional notifications
# SLACK_WEBHOOK_URL=
# PAGERDUTY_API_KEY=

# Email escalation (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ESCALATION_EMAILS=devops@company.com,oncall@company.com
SERVICE_ESCALATION_EMAILS_JSON={"checkout":["checkout-team@company.com"],"payments":["payments-team@company.com"],"auth":["security-team@company.com"],"orders":["orders-team@company.com"]}

# Default: CSV polling on. Set to false for webhook-only demos (no data/alerts.csv ingestion).
# ENABLE_CSV_POLLING=false

# --- Sandbox autonomous remediation demo (optional) ---
WEBHOOK_SHARED_SECRET=
ENABLE_REAL_SANDBOX_FIXES=false
DEMO_SERVICE_URL=http://127.0.0.1:5055
DEMO_SERVICE_PORT=5055
DEMO_MONITOR_INTERVAL_MS=3000
# Where the monitor POSTs alerts (dedicated webhook route)
DEMO_WEBHOOK_URL=http://127.0.0.1:5000/api/webhooks/demo
# Min time between webhook sends when the edge fires (safety against flapping)
DEMO_MONITOR_COOLDOWN_MS=60000

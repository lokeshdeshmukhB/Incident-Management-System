# Copy to `server/.env` (or repo root `.env`) and fill in values.
# See README for Supabase and Groq setup.

SUPABASE_URL=
SUPABASE_ANON_KEY=
GROQ_API_KEY_1=

# Optional notifications
# SLACK_WEBHOOK_URL=
# PAGERDUTY_API_KEY=

# Email escalation (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ESCALATION_EMAILS=devops@company.com,oncall@company.com
SERVICE_ESCALATION_EMAILS_JSON={"checkout":["checkout-team@company.com"],"payments":["payments-team@company.com"],"auth":["security-team@company.com"],"orders":["orders-team@company.com"]}
